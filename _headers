/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://app.cal.com https://cal.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; frame-src https://cal.com https://app.cal.com https://www.youtube.com https://www.youtube-nocookie.com; connect-src 'self' https://app.cal.com https://cal.com; font-src 'self';
